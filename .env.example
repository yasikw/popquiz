# ====================================
# PopQuiz - Environment Variables
# ====================================
# Copy this file to .env and fill in the values.
# DO NOT commit .env to version control.

# --- Required ---

# Google Gemini API Key
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# PostgreSQL connection string
# Example: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# --- Optional ---

# Node environment: development | production
NODE_ENV=development

# Comma-separated list of allowed CORS origins (production only)
# Example: https://example.com,https://app.example.com
ALLOWED_ORIGINS=

# Comma-separated list of admin user IDs (for elevated permissions)
ADMIN_USER_IDS=

# Cookie domain for session cookies (production only)
COOKIE_DOMAIN=

# Content Security Policy level: level1 | level2 | level3
CSP_LEVEL=level1

# Force strict CORS even in development
FORCE_STRICT_CORS=

# --- Replit-managed (auto-set on Replit) ---
# REPLIT_DOMAINS
# REPL_SLUG
# REPL_OWNER
