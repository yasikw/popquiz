# Environment Configuration Example
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# JWT Secrets
JWT_ACCESS_SECRET=your-super-secure-access-token-secret-key-here
JWT_REFRESH_SECRET=your-super-secure-refresh-token-secret-key-here
JWT_SECRET=your-legacy-jwt-secret-for-backward-compatibility

# Session Secret
SESSION_SECRET=your-super-secure-session-secret-key-here

# API Keys
GEMINI_API_KEY=your-google-gemini-api-key-here
GOOGLE_API_KEY=alternative-google-api-key

# CORS Configuration (Production)
# Comma-separated list of allowed origins for production
ALLOWED_ORIGINS=https://your-production-domain.com,https://api.your-production-domain.com,https://admin.your-production-domain.com

# Replit Configuration (Auto-populated in Replit environment)
REPL_ID=your-repl-id
REPL_SLUG=your-repl-slug
REPL_OWNER=your-username
REPLIT_DOMAINS=your-domain.repl.co,custom-domain.com

# Force strict CORS in development (optional)
# FORCE_STRICT_CORS=true

# Production SSL Configuration
# SSL_ENABLED=true
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem

# Rate Limiting
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

# Security Headers
# ENABLE_HSTS=true
# HSTS_MAX_AGE=31536000