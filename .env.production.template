# ================================
# PRODUCTION ENVIRONMENT TEMPLATE
# ================================
# Copy this file to .env.production and fill in your actual production values
# NEVER commit actual production secrets to version control

# ================================
# CORE APPLICATION SETTINGS
# ================================
NODE_ENV=production
PORT=5000

# ================================
# DATABASE CONFIGURATION
# ================================
# Production PostgreSQL database URL
# Format: postgresql://username:password@host:port/database?sslmode=require
DATABASE_URL="postgresql://username:password@host:port/database?sslmode=require"

# Database connection pool settings
PGDATABASE=your_production_db_name
PGHOST=your_production_db_host
PGPORT=5432
PGUSER=your_production_db_user
PGPASSWORD=your_production_db_password

# ================================
# SECURITY SECRETS
# ================================
# JWT Secret - MUST be a strong, random 256-bit key
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="CHANGE_ME_TO_64_CHAR_RANDOM_HEX_STRING_FOR_PRODUCTION_USE_ONLY"

# Session Secret - MUST be a strong, random key different from JWT_SECRET
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="CHANGE_ME_TO_DIFFERENT_64_CHAR_RANDOM_HEX_STRING_FOR_SESSIONS"

# ================================
# EXTERNAL API KEYS
# ================================
# Google Gemini AI API Key for quiz generation
GEMINI_API_KEY="your_gemini_api_key_here"
GOOGLE_API_KEY="your_google_api_key_here"

# ================================
# REPLIT AUTHENTICATION (if using)
# ================================
# Replit OAuth settings for authentication
REPLIT_DOMAINS="your-production-domain.replit.app"
ISSUER_URL="https://replit.com/oidc"
REPL_ID="your_repl_id_here"

# ================================
# SECURITY CONFIGURATION
# ================================
# Rate limiting settings (requests per hour)
API_RATE_LIMIT=100
UPLOAD_RATE_LIMIT=10
AUTH_RATE_LIMIT=5
REGISTER_RATE_LIMIT=3
QUIZ_RATE_LIMIT=20

# CSRF Protection
CSRF_ENABLED=true

# Security logging
SECURITY_LOG_LEVEL=info
SECURITY_LOG_FILE=/var/log/app/security.log

# ================================
# SSL/TLS CONFIGURATION
# ================================
# Force HTTPS in production
FORCE_HTTPS=true
HTTPS_PORT=443

# HSTS settings (HTTP Strict Transport Security)
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=true

# SSL certificate paths (if self-hosting)
SSL_CERT_PATH=/path/to/ssl/cert.pem
SSL_KEY_PATH=/path/to/ssl/private.key

# ================================
# MONITORING & LOGGING
# ================================
# Application logging
LOG_LEVEL=warn
LOG_FORMAT=json

# Performance monitoring
ENABLE_PERFORMANCE_MONITORING=true
PERFORMANCE_SAMPLE_RATE=0.1

# Error reporting
ERROR_REPORTING_ENABLED=true
ERROR_REPORTING_SERVICE_URL=""

# ================================
# PRODUCTION OPTIMIZATIONS
# ================================
# Disable debug features
DEBUG=false
ENABLE_SOURCE_MAPS=false
ENABLE_HOT_RELOAD=false

# Memory and performance settings
MAX_MEMORY_USAGE=512
MAX_CPU_USAGE=80
WORKER_THREADS=2

# File upload restrictions
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,txt,doc,docx

# ================================
# BACKUP & DISASTER RECOVERY
# ================================
# Database backup settings
DB_BACKUP_ENABLED=true
DB_BACKUP_SCHEDULE="0 2 * * *"
DB_BACKUP_RETENTION_DAYS=30

# ================================
# COMPLIANCE & AUDIT
# ================================
# Audit logging
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=365

# Data retention policies
USER_DATA_RETENTION_DAYS=2555  # 7 years
SESSION_DATA_RETENTION_DAYS=30
LOG_DATA_RETENTION_DAYS=90