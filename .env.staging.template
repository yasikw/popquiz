# ================================
# STAGING ENVIRONMENT TEMPLATE
# ================================
# Copy this file to .env.staging for staging environment
# Use production-like settings but with staging resources

# ================================
# CORE APPLICATION SETTINGS
# ================================
NODE_ENV=staging
PORT=5000

# ================================
# DATABASE CONFIGURATION
# ================================
# Staging PostgreSQL database URL
DATABASE_URL="postgresql://staging_user:staging_password@staging_host:5432/staging_db?sslmode=require"

PGDATABASE=staging_quiz_app
PGHOST=staging-db.example.com
PGPORT=5432
PGUSER=staging_user
PGPASSWORD=staging_password

# ================================
# SECURITY SECRETS
# ================================
# Staging JWT Secret - Use different keys than production
JWT_SECRET="STAGING_64_CHAR_RANDOM_HEX_STRING_DIFFERENT_FROM_PRODUCTION"
SESSION_SECRET="STAGING_64_CHAR_RANDOM_HEX_STRING_FOR_SESSIONS_DIFFERENT"

# ================================
# EXTERNAL API KEYS
# ================================
# Use staging/test API keys
GEMINI_API_KEY="your_staging_gemini_api_key"
GOOGLE_API_KEY="your_staging_google_api_key"

# ================================
# REPLIT AUTHENTICATION
# ================================
REPLIT_DOMAINS="your-staging-domain.replit.app"
ISSUER_URL="https://replit.com/oidc"
REPL_ID="your_staging_repl_id"

# ================================
# SECURITY CONFIGURATION
# ================================
# More relaxed rate limits for testing
API_RATE_LIMIT=200
UPLOAD_RATE_LIMIT=20
AUTH_RATE_LIMIT=10
REGISTER_RATE_LIMIT=5
QUIZ_RATE_LIMIT=40

CSRF_ENABLED=true
FORCE_HTTPS=true

# ================================
# DEVELOPMENT FEATURES
# ================================
# Enable some debugging in staging
DEBUG=false
LOG_LEVEL=debug
ENABLE_SOURCE_MAPS=true
ENABLE_PERFORMANCE_MONITORING=true